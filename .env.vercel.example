# ─────────────────────────────────────────────────────────────────────────
# Import into Vercel → Project → Settings → Environment Variables → "Import .env"
# Replace [PASSWORD] with your Supabase database password.
# Host/region (aws-1-ap-southeast-2) and project ref are pre-filled.
# ─────────────────────────────────────────────────────────────────────────

# App runtime → Supabase TRANSACTION pooler (port 6543, serverless/IPv4-safe)
DATABASE_URL="postgresql://postgres.uxubotypikmjxzascwjo:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations/seed → Supabase SESSION pooler (port 5432, IPv4-safe)
DIRECT_URL="postgresql://postgres.uxubotypikmjxzascwjo:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Claude (live AI grading / tutor / chat / categorization). Leave blank for offline mode.
ANTHROPIC_API_KEY=

# Model for all AI features.
SPM_AI_MODEL=claude-opus-4-8

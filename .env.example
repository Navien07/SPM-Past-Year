# Copy to .env and fill in. The app runs without an API key (AI features use a
# deterministic mock), but set this to enable real Claude grading/tutoring/generation.
ANTHROPIC_API_KEY=

# Model used for all AI features. Defaults to claude-opus-4-8.
SPM_AI_MODEL=claude-opus-4-8

# SQLite for the POC. Swap for a Postgres URL in production.
DATABASE_URL="file:./dev.db"

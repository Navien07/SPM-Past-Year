// SPM AI LMS — data model
// SQLite for the POC (Json stored as text; enums modelled as String since
// SQLite has no native enum/array support). Swap the datasource to Postgres
// for production with no model changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: use the pooled connection for `url` (port 6543) and the direct
  // connection for `directUrl` (port 5432) so migrations bypass PgBouncer.
  directUrl = env("DIRECT_URL")
}

// ── Module 3: content taxonomy ────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Sejarah"
  nameEn    String? // e.g. "History"
  code      String   @unique // e.g. "SEJ"
  color     String   @default("#3470f4")
  createdAt DateTime @default(now())

  topics        Topic[]
  questions     Question[]
  papers        Paper[]
  enrollments   Enrollment[]
  knowledgeDocs KnowledgeDoc[]
}

model Topic {
  id        String  @id @default(cuid())
  subjectId String
  form      Int // 4 or 5
  chapter   Int // chapter number within the form
  title     String // chapter title
  subtopics String  @default("[]") // JSON string[]: named subtopics
  createdAt DateTime @default(now())

  subject            Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions          Question[]
  generatedQuestions GeneratedQuestion[]

  @@unique([subjectId, form, chapter])
  @@index([subjectId])
}

// ── Module 1: uploaded source papers ──────────────────────────────────────

model Paper {
  id            String   @id @default(cuid())
  title         String
  subjectId     String
  paperType     String // "past_year" | "trial" | "state" | "mock"
  year          Int
  state         String? // e.g. "Selangor" (for state/trial papers)
  paperNumber   Int      @default(1) // 1 or 2
  fileUrl       String? // local path under /public/uploads for the POC
  fileName      String?
  rawText       String? // extracted/pasted source text fed to the AI agent
  markingScheme String? // marking scheme / answer key text
  rubric        String? // JSON: essay rubric (criteria + bands)
  status        String   @default("uploaded") // uploaded | categorizing | categorized | failed
  categorizedAt DateTime?
  createdAt     DateTime @default(now())

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([subjectId])
  @@index([paperType])
}

// ── Module 2 output: categorized questions (the question bank) ─────────────

model Question {
  id            String   @id @default(cuid())
  subjectId     String
  topicId       String?
  paperId       String?
  paperNumber   Int      @default(1) // 1 (objective) or 2 (subjective/essay)
  questionType  String // "mcq" | "structured" | "essay"
  number        String? // question label in the source, e.g. "3(a)"
  stem          String // the question text
  options       String   @default("[]") // JSON [{key,text}] for MCQ
  answer        String? // correct option key (MCQ) or model answer
  markingScheme String? // marking notes for structured/essay
  rubric        String? // JSON rubric for essays
  marks         Int      @default(1)
  isKbat        Boolean  @default(false) // higher-order thinking (KBAT)
  subtopic      String?
  year          Int?
  source        String   @default("past_paper") // past_paper | ai_generated
  // Moderation (human-in-the-loop): AI-categorized questions await review,
  // unless the AI's confidence clears the auto-approve threshold.
  status        String   @default("approved") // pending | approved | rejected
  confidence    Float? // AI categorization confidence 0–1
  autoApproved  Boolean  @default(false) // approved by confidence gate, not a human
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())

  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic     Topic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
  paper     Paper?       @relation(fields: [paperId], references: [id], onDelete: SetNull)
  attempts  Attempt[]
  bookmarks Bookmark[]
  reviewItems ReviewItem[]

  @@index([subjectId])
  @@index([topicId])
  @@index([year])
  @@index([status])
}

// Bookmarked / flagged-for-review questions.
model Bookmark {
  id         String   @id @default(cuid())
  studentId  String
  questionId String
  createdAt  DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([studentId, questionId])
  @@index([studentId])
}

// Spaced repetition (Leitner): wrong/low answers resurface until mastered.
model ReviewItem {
  id           String   @id @default(cuid())
  studentId    String
  questionId   String
  box          Int      @default(0) // Leitner box 0..5 (higher = longer interval)
  dueAt        DateTime @default(now())
  lastScorePct Float    @default(0)
  reps         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([studentId, questionId])
  @@index([studentId, dueAt])
}

// ── Students & their work ─────────────────────────────────────────────────

model Student {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  form        Int       @default(5)
  school      String?
  age         Int?
  state       String?
  whatsapp    String? // phone / WhatsApp number for the pilot feedback group
  pdpaConsent Boolean   @default(false) // agreed to PDPA / privacy policy
  consentAt   DateTime?
  createdAt   DateTime  @default(now())

  attempts    Attempt[]
  sessions    StudySession[]
  user        User?
  enrollments Enrollment[]
  payments    Payment[]
  bookmarks   Bookmark[]
  reviewItems ReviewItem[]
}

// ── Auth & roles ──────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String // "admin" | "student" (admin also handles review/moderation)
  password  String // scrypt hash "salt:hash"
  studentId String?  @unique // set for student-role users
  createdAt DateTime @default(now())

  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([role])
}

// ── Enrollments & payments (admin dashboard) ──────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  status    String   @default("active") // active | paused | completed
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@index([studentId])
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  amount      Float
  currency    String   @default("MYR")
  method      String? // fpx | card | ewallet | cash
  status      String   @default("paid") // paid | pending | failed | refunded
  description String?
  paidAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ── Knowledge base ("main brain") — admin-ingested reference notes that ground
// the Cikgu AI chat. Lexical retrieval for the POC; swap for pgvector later.
model KnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  subjectId String?
  form      Int? // 4 or 5 (optional)
  kind      String   @default("note") // note | textbook | summary
  source    String? // where it came from (admin-provided)
  content   String // the reference text
  createdAt DateTime @default(now())

  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([subjectId])
}

// Module 4/5: an attempt is one answered question, graded instantly by the AI.
model Attempt {
  id            String   @id @default(cuid())
  studentId     String
  questionId    String
  answer        String // student's submitted answer
  score         Float    @default(0) // marks awarded
  maxScore      Float    @default(1)
  band          String? // qualitative band, e.g. "Cemerlang" / "Band 5"
  isCorrect     Boolean? // for MCQ
  feedback      String? // JSON: { summary, strengths[], improvements[], criteria[] }
  gradedByAi    Boolean  @default(false) // false => mock/offline grading
  timeSpentSec  Int      @default(0)
  createdAt     DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([questionId])
}

// Module 6: progress / time analytics
model StudySession {
  id           String   @id @default(cuid())
  studentId    String
  subjectId    String?
  durationSec  Int      @default(0)
  questionsDone Int     @default(0)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// Module 5: AI-generated practice questions (KBAT, pattern-matched)
model GeneratedQuestion {
  id           String   @id @default(cuid())
  topicId      String
  questionType String // mcq | structured | essay
  stem         String
  options      String   @default("[]") // JSON
  answer       String?
  markingScheme String?
  rubric       String?
  marks        Int      @default(1)
  isKbat       Boolean  @default(true)
  basedOn      String? // note on the pattern/source it mimics
  createdAt    DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

// Module 6: assembled mock papers
model MockPaper {
  id          String   @id @default(cuid())
  title       String
  subjectId   String
  paperNumber Int      @default(1)
  questionIds String   @default("[]") // JSON string[]: Question ids in order
  createdAt   DateTime @default(now())
}

// Trace logging — every notable user action, viewable by the admin.
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  studentId String?
  name      String? // denormalised for easy admin display
  role      String?
  action    String // e.g. "login", "attempt.graded", "paper.categorize"
  detail    String?
  path      String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([studentId])
  @@index([action])
}

// Waitlist — captured when the free pilot is full (or from the landing page),
// so we can invite students as more spots open.
model Waitlist {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  whatsapp  String?
  school    String?
  state     String?
  note      String?
  invited   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Web Push subscriptions (PWA notifications). One row per browser/device.
model PushSubscription {
  id        String   @id @default(cuid())
  studentId String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([studentId])
}

// Password reset tokens (forgot/reset flow).
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
